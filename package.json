{
  "name": "blastscope",
  "version": "1.0.0",
  "description": "Blast Assessment & Material Response Analysis Platform",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && electron .",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "build:solver": "node scripts/build-solver.js",
    "start": "electron .",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder -wml",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "lucide-react": "^0.395.0",
    "plotly.js-dist-min": "^2.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plotly.js": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^26.15.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.drdo.blastscope",
    "productName": "BlastScope",
    "directories": {
      "output": "dist-package"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-dist/blastscope-solver",
        "to": "backend-dist/blastscope-solver",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
