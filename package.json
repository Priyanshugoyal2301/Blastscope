{
  "name": "blastscope",
  "version": "1.0.0",
  "description": "Blast Assessment & Material Response Analysis Platform",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && electron .",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "start": "electron ."
  },
  "dependencies": {
    "lucide-react": "^0.395.0",
    "plotly.js-dist-min": "^2.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plotly.js": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.12"
  }
}
